
<?xml version="1.0"?>

<robot name="smorphi">

  <!-- ================= BASE ================= -->

  <link name="base_link">

    <!-- VISUAL -->
    <visual>

      <origin xyz="0 0 0.13" rpy="0 0 0"/>

      <geometry>
        <mesh filename="file:///home/alicia/rbrz_ws/src/smorphi_description/meshes/body.stl"
              scale="1 1 1"/>
      </geometry>

    </visual>

    <!-- COLLISION -->
    <collision>

      <origin xyz="0 0 0.13" rpy="0 0 0"/>

      <geometry>
        <box size="0.17 0.17 0.208"/>
      </geometry>

    </collision>

    <!-- INERTIA -->
    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="5.0"/>

      <inertia
        ixx="0.1"
        ixy="0.0"
        ixz="0.0"
        iyy="0.1"
        iyz="0.0"
        izz="0.1"/>

    </inertial>

  </link>

  <!-- ================= WHEEL FL ================= -->

  <link name="wheel_fl">

    <visual>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="file:///home/alicia/rbrz_ws/src/smorphi_description/meshes/wheel_fl.stl"
              scale="1 1 1"/>
      </geometry>

    </visual>

    <collision>

      <origin xyz="0 0 0" rpy="1.5708 0 0"/>

      <geometry>
        <cylinder radius="0.034" length="0.02"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.001"/>

    </inertial>

  </link>

  <joint name="joint_wheel_fl" type="continuous">

    <parent link="base_link"/>
    <child link="wheel_fl"/>

    <origin xyz="0.055 -0.070 0.034" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>

  <!-- ================= WHEEL FR ================= -->

  <link name="wheel_fr">

    <visual>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="file:///home/alicia/rbrz_ws/src/smorphi_description/meshes/wheel_fr.stl"
              scale="1 1 1"/>
      </geometry>

    </visual>

    <collision>

      <origin xyz="0 0 0" rpy="1.5708 0 0"/>

      <geometry>
        <cylinder radius="0.034" length="0.02"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.001"/>

    </inertial>

  </link>

  <joint name="joint_wheel_fr" type="continuous">

    <parent link="base_link"/>
    <child link="wheel_fr"/>

    <origin xyz="0.055 0.050 0.034" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>

  <!-- ================= WHEEL RL ================= -->

  <link name="wheel_rl">

    <visual>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="file:///home/alicia/rbrz_ws/src/smorphi_description/meshes/wheel_rl.stl"
              scale="1 1 1"/>
      </geometry>

    </visual>

    <collision>

      <origin xyz="0 0 0" rpy="1.5708 0 0"/>

      <geometry>
        <cylinder radius="0.034" length="0.02"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.001"/>

    </inertial>

  </link>

  <joint name="joint_wheel_rl" type="continuous">

    <parent link="base_link"/>
    <child link="wheel_rl"/>

    <origin xyz="-0.025 -0.070 0.034" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>

  <!-- ================= WHEEL RR ================= -->

  <link name="wheel_rr">

    <visual>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <mesh filename="file:///home/alicia/rbrz_ws/src/smorphi_description/meshes/wheel_rr.stl"
              scale="1 1 1"/>
      </geometry>

    </visual>

    <collision>

      <origin xyz="0 0 0" rpy="1.5708 0 0"/>

      <geometry>
        <cylinder radius="0.034" length="0.02"/>
      </geometry>

    </collision>

    <inertial>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="0.2"/>

      <inertia
        ixx="0.001"
        ixy="0.0"
        ixz="0.0"
        iyy="0.001"
        iyz="0.0"
        izz="0.001"/>

    </inertial>

  </link>

  <joint name="joint_wheel_rr" type="continuous">

    <parent link="base_link"/>
    <child link="wheel_rr"/>

    <origin xyz="-0.025 0.050 0.034" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>

<!---============OBSTACLE_SENSOR===================-->
<link name="obstacle_sensor_link">
  <visual>
    <geometry>
      <box size="0.03 0.02 0.02"/>
    </geometry>
  </visual>
</link>

<joint name="obstacle_sensor_joint" type="fixed">
  <parent link="base_link"/>
  <child link="obstacle_sensor_link"/>
  <origin xyz="0.11 0 0.10" rpy="0 0 0"/>
</joint>

    <gazebo reference="obstacle_sensor_link">
      <sensor name="front_obstacle_sensor" type="gpu_lidar">
        <topic>/front_obstacle_scan</topic>
        <update_rate>10</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>15</samples>
              <resolution>1</resolution>
              <min_angle>-0.35</min_angle>
              <max_angle>0.35</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.03</min>
            <max>2.0</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </gazebo>

<!-- ================= LINE SENSORS ================= -->

<!-- LEFT SENSOR -->
<link name="line_left_link">

  <visual>
    <geometry>
      <box size="0.04 0.02 0.02"/>
    </geometry>

    <material>
      <ambient>0 1 0 1</ambient>
      <diffuse>0 1 0 1</diffuse>
    </material>
  </visual>

</link>

<!-- CENTER SENSOR -->
<link name="line_center_link">

  <visual>
    <geometry>
      <box size="0.04 0.02 0.02"/>
    </geometry>

    <material>
      <ambient>0 1 0 1</ambient>
      <diffuse>0 1 0 1</diffuse>
    </material>
  </visual>

</link>

<!-- RIGHT SENSOR -->
<link name="line_right_link">

  <visual>
    <geometry>
      <box size="0.04 0.02 0.02"/>
    </geometry>

    <material>
      <ambient>0 1 0 1</ambient>
      <diffuse>0 1 0 1</diffuse>
    </material>
  </visual>

</link>

<!-- JOINTS -->

<joint name="line_left_joint" type="fixed">
  <parent link="base_link"/>
  <child link="line_left_link"/>
  <origin xyz="0.08 -0.015 0.02" rpy="0 -1.5708 0"/>
</joint>

<joint name="line_center_joint" type="fixed">
  <parent link="base_link"/>
  <child link="line_center_link"/>
  <origin xyz="0.08 0 0.02" rpy="0 -1.5708 0"/>
</joint>

<joint name="line_right_joint" type="fixed">
  <parent link="base_link"/>
  <child link="line_right_link"/>
  <origin xyz="0.08 0.015 0.02" rpy="0 -1.5708 0"/>
</joint>

<!-- LEFT SENSOR -->

<gazebo reference="line_left_link">
  <sensor name="line_left_sensor" type="gpu_lidar">

    <topic>/line_left_scan</topic>

    <update_rate>20</update_rate>

    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.01</min>
        <max>0.20</max>
        <resolution>0.001</resolution>
      </range>
    </ray>

    <always_on>1</always_on>
    <visualize>true</visualize>

  </sensor>
</gazebo>

<!-- CENTER SENSOR -->

<gazebo reference="line_center_link">
  <sensor name="line_center_sensor" type="gpu_lidar">

    <topic>/line_center_scan</topic>

    <update_rate>20</update_rate>

    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.01</min>
        <max>0.20</max>
        <resolution>0.001</resolution>
      </range>
    </ray>

    <always_on>1</always_on>
    <visualize>true</visualize>

  </sensor>
</gazebo>

<!-- RIGHT SENSOR -->

<gazebo reference="line_right_link">
  <sensor name="line_right_sensor" type="gpu_lidar">

    <topic>/line_right_scan</topic>

    <update_rate>20</update_rate>

    <ray>
      <scan>
        <horizontal>
          <samples>1</samples>
          <resolution>1</resolution>
          <min_angle>0</min_angle>
          <max_angle>0</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.01</min>
        <max>0.20</max>
        <resolution>0.001</resolution>
      </range>
    </ray>

    <always_on>1</always_on>
    <visualize>true</visualize>

  </sensor>
</gazebo>
  <!-- ================= GAZEBO PLUGINS ================= -->

    <gazebo>
      <plugin
        filename="gz-sim-joint-state-publisher-system"
        name="gz::sim::systems::JointStatePublisher"/>
    </gazebo>

    <gazebo>
      <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">

        <left_joint>joint_wheel_fl</left_joint>
        <left_joint>joint_wheel_rl</left_joint>

        <right_joint>joint_wheel_fr</right_joint>
        <right_joint>joint_wheel_rr</right_joint>

        <wheel_separation>0.124</wheel_separation>
        <wheel_radius>0.024</wheel_radius>

        <topic>/cmd_vel</topic>

      </plugin>
    </gazebo>

  </robot>
